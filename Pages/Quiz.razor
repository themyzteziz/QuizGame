    private void ShuffleQuestions()
    {
        var random = new Random();

        foreach (var question in questions)
        {
            question.Options = question.Options
                .OrderBy(x => random.Next())
                .ToList();
        }
    }

    private void SelectSingleOption(int index)
    {
        if (answerSubmitted)
            return;

        selectedSingleIndex = index;
        StateHasChanged();
    }

    private void ToggleMultipleOption(int index)
    {
        if (answerSubmitted)
            return;

        if (selectedMultipleIndices.Contains(index))
            selectedMultipleIndices.Remove(index);
        else
            selectedMultipleIndices.Add(index);

        StateHasChanged();
    }

    private void SubmitAnswer()
    {
        if (answerSubmitted)
            return;

        bool isCorrect = false;
        var question = CurrentQuestion;

        if (question.Type == QuestionType.SingleChoice)
        {
            if (selectedSingleIndex is null)
                return;

            isCorrect = question.Options[selectedSingleIndex.Value].IsCorrect;
        }
        else if (question.Type == QuestionType.MultipleChoice)
        {
            var correctIndices = question.Options
                .Select((option, index) => new { option, index })
                .Where(x => x.option.IsCorrect)
                .Select(x => x.index)
                .ToHashSet();

            isCorrect = selectedMultipleIndices.SetEquals(correctIndices);
        }
        else if (question.Type == QuestionType.Text)
        {
            isCorrect = IsTextAnswerCorrect(textAnswer, question);
        }
        else if (question.Type == QuestionType.Text)
        {
            int earnedPoints = GetTextAnswerPoints(textAnswer, question);
            isCorrect = earnedPoints > 0;
            score += earnedPoints;
        }

        lastAnswerCorrect = isCorrect;

        if (isCorrect)
        {
            score += question.Points;
        }

        answerSubmitted = true;
    }

    private bool IsTextAnswerCorrect(string userAnswer, QuizQuestion question)
    {
        var normalizedUserAnswer = Normalize(userAnswer);

        if (string.IsNullOrWhiteSpace(normalizedUserAnswer))
            return false;

        // Om keywords finns, använd dem i första hand
        if (question.Keywords.Any())
        {
            int matchCount = question.Keywords.Count(keyword =>
                normalizedUserAnswer.Contains(Normalize(keyword)));

            return matchCount >= question.RequiredKeywordMatches;
        }

        // Fallback till gamla accepted answers
        int acceptedMatchCount = question.AcceptedAnswers.Count(answer =>
            normalizedUserAnswer.Contains(Normalize(answer)));

        if (question.AcceptedAnswers.Count == 0)
            return false;

        return acceptedMatchCount >= 1;
    }

    private int GetTextAnswerPoints(string userAnswer, QuizQuestion question)
    {
        var normalizedUserAnswer = Normalize(userAnswer);

        if (string.IsNullOrWhiteSpace(normalizedUserAnswer) || !question.Keywords.Any())
            return 0;

        int matchCount = question.Keywords.Count(keyword =>
            normalizedUserAnswer.Contains(Normalize(keyword)));

        if (matchCount >= question.RequiredKeywordMatches + 1)
            return question.Points;

        if (matchCount >= question.RequiredKeywordMatches)
            return Math.Max(1, question.Points / 2);

        return 0;
    }

    private static string Normalize(string input)
    {
        return input.Trim().ToLowerInvariant();
    }

    private string GetSingleOptionClass(int index)
    {
        var option = CurrentQuestion.Options[index];

        if (!answerSubmitted)
        {
            return selectedSingleIndex == index ? "selected" : "";
        }

        if (option.IsCorrect)
            return "correct";

        if (selectedSingleIndex == index && !option.IsCorrect)
            return "wrong";

        return "dimmed";
    }

    private string GetMultipleOptionClass(int index)
    {
        var option = CurrentQuestion.Options[index];
        bool isSelected = selectedMultipleIndices.Contains(index);

        if (!answerSubmitted)
        {
            return isSelected ? "selected" : "";
        }

        if (option.IsCorrect)
            return "correct";

        if (isSelected && !option.IsCorrect)
            return "wrong";

        return "dimmed";
    }

    private string GetCorrectAnswersText(QuizQuestion question)
    {
        return string.Join(", ", question.Options.Where(o => o.IsCorrect).Select(o => o.Text));
    }

    private string GetSectionName(QuestionType type)
    {
        return type switch
        {
            QuestionType.SingleChoice => "A",
            QuestionType.MultipleChoice => "A",
            QuestionType.Text => "B",
            _ => "?"
        };
    }

    private void NextQuestion()
    {
        if (currentIndex < questions.Count - 1)
        {
            currentIndex++;
            ResetQuestionState();
        }
        else
        {
            isFinished = true;
        }
    }

    private void RestartQuiz()
    {
        currentIndex = 0;
        score = 0;
        isFinished = false;
        ResetQuestionState();
    }

    private void ResetQuestionState()
    {
        answerSubmitted = false;
        lastAnswerCorrect = false;
        selectedSingleIndex = null;
        selectedMultipleIndices.Clear();
        textAnswer = string.Empty;
    }
