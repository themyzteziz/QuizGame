@page "/systemtest"
@using QuizApp.Models

<div class="quiz-page">
    <div class="quiz-card">
        <h1>Systemtest Quiz</h1>
        <p class="quiz-meta">
            Maxpoäng: @MaxPoints p | Godkänt: @PassingPoints p (@PassingPercent%)
        </p>

        @if (!isFinished)
        {
            var question = CurrentQuestion;

            <p class="question-count">Fråga @(currentIndex + 1) / @questions.Count</p>
            <p class="question-points">Del @GetSectionName(question.Type) – @question.Points p</p>

            <h2 class="question-title">@question.Title</h2>

            @if (!string.IsNullOrWhiteSpace(question.Prompt))
            {
                <p class="question-prompt">@question.Prompt</p>
            }

            @if (!answerSubmitted)
            {
                @if (question.Type == QuestionType.SingleChoice)
                {
                    <p class="pick-text">Välj ett svar</p>

                    <div class="options">
                        @for (int i = 0; i < question.Options.Count; i++)
                        {
                            int index = i;

                            <button type="button"
                                    class="option-btn @(answerSubmitted? GetSingleOptionClass(index) : (selectedSingleIndex == index ? "selected" : ""))"
                                    @onclick="@(() => SelectSingleOption(index))">
                                @question.Options[i].Text
                            </button>
                        }
                    </div>

                    <button class="submit-btn"
                            @onclick="SubmitAnswer"
                            disabled="@(selectedSingleIndex is null)">
                        Submit Answer
                    </button>
                }
                else if (question.Type == QuestionType.MultipleChoice)
                {
                    <p class="pick-text">Välj alla som stämmer</p>

                    <div class="options">
                        @for (int i = 0; i < question.Options.Count; i++)
                        {
                            int index = i;

                            <button type="button"
                                    class="option-btn @(answerSubmitted? GetMultipleOptionClass(index) : (selectedMultipleIndices.Contains(index) ? "selected" : ""))"
                                    @onclick="@(() => ToggleMultipleOption(index))">
                                @question.Options[i].Text
                            </button>
                        }
                    </div>

                    <button class="submit-btn"
                            @onclick="SubmitAnswer"
                            disabled="@(!selectedMultipleIndices.Any())">
                        Submit Answer
                    </button>
                }
                else if (question.Type == QuestionType.Text)
                {
                    <p class="pick-text">Skriv ditt svar</p>

                    <textarea class="text-answer"
                              @bind="textAnswer"
                              placeholder="Skriv ditt svar här..."></textarea>

                    <button class="submit-btn"
                            @onclick="SubmitAnswer"
                            disabled="@string.IsNullOrWhiteSpace(textAnswer)">
                        Submit Answer
                    </button>
                }
            }
            else
            {
                <div class="feedback-box @(lastAnswerCorrect ? "correct-box" : "wrong-box")">
                    <h3>@(lastAnswerCorrect ? $"Rätt! +{question.Points}p 🎉" : "Fel ❌")</h3>

                    @if (question.Type == QuestionType.Text)
                    {
                        <p><strong>Godkända svar / nyckelidéer:</strong> @string.Join(" | ", question.AcceptedAnswers)</p>
                    }
                    else
                    {
                        <p><strong>Rätt svar:</strong> @GetCorrectAnswersText(question)</p>
                    }
                </div>

                <button class="next-btn" @onclick="NextQuestion">
                    @(currentIndex == questions.Count - 1 ? "Visa resultat" : "Nästa fråga")
                </button>
            }
        }
        else
        {
            <div class="final-result">
                <h2>Quiz klart</h2>
                <p class="final-score">Du fick <strong>@score / @MaxPoints</strong> poäng</p>

                <p class="final-status @(score >= PassingPoints ? "pass" : "fail")">
                    @(score >= PassingPoints ? "Godkänd" : "Inte godkänd")
                </p>

                <button class="next-btn" @onclick="RestartQuiz">Börja om</button>
            </div>
        }

        <p class="running-score">Poäng hittills: @score / @MaxPoints</p>
    </div>
</div>

